{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "User's profile photo URL" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User's role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "displayName", "email", "role"]
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "A chat session metadata",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Session ID" },
        "userId": { "type": "string", "description": "Owner's user ID" },
        "title": { "type": "string", "description": "Session title" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["id", "userId", "title", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a chat session",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Message ID" },
        "role": { "type": "string", "enum": ["user", "model"], "description": "Sender role" },
        "text": { "type": "string", "description": "Message content" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Message timestamp" },
        "groundingChunks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "uri": { "type": "string" },
              "type": { "type": "string", "enum": ["web", "maps"] }
            }
          }
        }
      },
      "required": ["id", "role", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/chatSessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "Chat session metadata"
    },
    "/chatSessions/{sessionId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a session"
    }
  }
}
